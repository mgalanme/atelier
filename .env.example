# Copy this file to .env and fill in the real values.
# Never commit the real .env file.

# Databricks Free Edition workspace (reused from previous case studies)
DATABRICKS_HOST=https://dbc-d9cdf0a6-0761.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/REPLACE_WITH_WAREHOUSE_ID
DATABRICKS_TOKEN=REPLACE_WITH_PERSONAL_ACCESS_TOKEN

# Unity Catalog target for this project
ATELIER_CATALOG=atelier
ATELIER_SCHEMA_BRONZE=bronze
ATELIER_SCHEMA_SILVER=silver
ATELIER_SCHEMA_GOLD=gold

# Mosaic AI Model Serving endpoints (created in the Setup Guide)
MOSAIC_LLM_ENDPOINT=https://dbc-d9cdf0a6-0761.cloud.databricks.com/serving-endpoints/atelier-llm
MOSAIC_TREND_AGENT_ENDPOINT=https://dbc-d9cdf0a6-0761.cloud.databricks.com/serving-endpoints/atelier-trend-agent
MOSAIC_SUSTAINABILITY_AGENT_ENDPOINT=https://dbc-d9cdf0a6-0761.cloud.databricks.com/serving-endpoints/atelier-sustainability-agent
MOSAIC_STORYTELLING_AGENT_ENDPOINT=https://dbc-d9cdf0a6-0761.cloud.databricks.com/serving-endpoints/atelier-storytelling-agent
MOSAIC_BUYER_AGENT_ENDPOINT=https://dbc-d9cdf0a6-0761.cloud.databricks.com/serving-endpoints/atelier-buyer-agent

# Solace broker (self-hosted PubSub+ Standard, open source, free)
SOLACE_BROKER_URL=tcp://localhost:55555
SOLACE_VPN=default
SOLACE_USERNAME=admin
SOLACE_PASSWORD=REPLACE_WITH_BROKER_PASSWORD
SOLACE_NAMESPACE=atelier/

# GitHub
GITHUB_REPO=mgalanme/atelier
